# =============================================================================
# Environment Variables — CV Generator
# =============================================================================
# Copy this file to .env for local development.
# On Render: set these in the Render dashboard or via render.yaml.
# DO NOT commit .env to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED
# -----------------------------------------------------------------------------
# Claude API key — get from https://console.anthropic.com/settings/keys
CLAUDE_API_KEY=sk-ant-api03-your-api-key-here

# -----------------------------------------------------------------------------
# RENDER FREE TIER — Keep-alive (prevents spin-down after 15 min inactivity)
# -----------------------------------------------------------------------------
# Enable the self-ping scheduler
KEEPALIVE_ENABLED=true

# Your Render service URL — set this after first deploy
# Example: https://pranav-cv-generator.onrender.com
KEEPALIVE_URL=https://your-app-name.onrender.com

# -----------------------------------------------------------------------------
# OPTIONAL — Google Sheets integration
# -----------------------------------------------------------------------------
# Webhook URL from your Google Apps Script web app (see README)
GOOGLE_SHEETS_WEBHOOK=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# -----------------------------------------------------------------------------
# OPTIONAL — Server
# -----------------------------------------------------------------------------
# Render injects PORT=10000 automatically for Docker services.
# For local dev the default is 8055 (set in application.properties).
# PORT=8055

# -----------------------------------------------------------------------------
# LOCAL DEV OVERRIDES
# Leave these commented out on Render — defaults are already prod-safe.
# -----------------------------------------------------------------------------
# Enable H2 browser console at /h2-console
# H2_CONSOLE_ENABLED=true

# Disable Thymeleaf template cache for hot reload
# THYMELEAF_CACHE=false

# Log SQL queries to console
# JPA_SHOW_SQL=true

# Verbose application logging
# LOG_LEVEL_APP=DEBUG
